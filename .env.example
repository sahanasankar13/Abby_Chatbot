# Required environment variables
OPENAI_API_KEY=your_openai_api_key_here
ABORTION_POLICY_API_KEY=your_abortion_policy_api_key_here
SESSION_SECRET=your_session_secret_here

# Optional environment variables
# DATABASE_URL=your_database_url_here  # Required only if using a database for storage
# AWS_REGION=your_aws_region_here      # Required only for AWS CloudWatch metrics